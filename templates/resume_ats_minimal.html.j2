<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ variant.title }}</title>
    <style>
      @page {
        size: Letter;
        margin: 0.55in 0.55in 0.68in;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: #111827;
        background: #ffffff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      .page {
        max-width: 8.5in;
        margin: 0 auto;
        padding-bottom: 0.08in;
      }

      .header {
        margin-bottom: 0.16in;
      }

      .header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.16in;
      }

      .name {
        margin: 0;
        font-size: 25px;
        line-height: 1.05;
        font-weight: 700;
      }

      .headline {
        margin-top: 6px;
        font-size: 11px;
        line-height: 1.3;
        color: #374151;
      }

      .header-meta {
        text-align: right;
        font-size: 9px;
        line-height: 1.2;
        color: #4b5563;
        white-space: nowrap;
        padding-top: 2px;
      }

      .contact {
        margin-top: 8px;
        font-size: 9.8px;
        line-height: 1.45;
      }

      .contact div {
        margin-bottom: 2px;
      }

      .contact a {
        color: #1f4f7a;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      .section {
        margin-bottom: 0.14in;
      }

      .section-title {
        margin: 0 0 0.06in;
        font-size: 11px;
        line-height: 1.1;
        font-weight: 700;
        text-transform: uppercase;
        border-bottom: 1px solid #9ca3af;
        padding-bottom: 3px;
      }

      .body-text,
      .meta,
      .project-links,
      .subproject-links {
        font-size: 10px;
        line-height: 1.35;
      }

      .meta {
        color: #4b5563;
      }

      .entry {
        margin-bottom: 0.11in;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .entry-head {
        display: flex;
        justify-content: space-between;
        gap: 0.12in;
        align-items: baseline;
      }

      .entry-title-line {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
      }

      .entry-role {
        font-size: 11px;
        font-weight: 700;
      }

      .entry-company {
        margin-top: 2px;
        font-size: 10px;
        color: #4b5563;
      }

      .entry-dates {
        font-size: 9.5px;
        color: #4b5563;
        white-space: nowrap;
      }

      .entry-summary {
        margin-top: 4px;
        font-size: 10px;
        line-height: 1.35;
      }

      .badge {
        display: inline-block;
        padding: 1px 5px;
        border: 1px solid #cbd5e1;
        font-size: 7.5px;
        line-height: 1.2;
        text-transform: uppercase;
      }

      .project-links,
      .subproject-links {
        margin-top: 4px;
        color: #4b5563;
      }

      .project-links a,
      .subproject-links a {
        color: #1f4f7a;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      ul {
        margin: 0.04in 0 0 0.16in;
        padding: 0;
      }

      li {
        margin-bottom: 2px;
        font-size: 10px;
        line-height: 1.3;
      }

      .line-block {
        margin-bottom: 0.06in;
      }

      .group-label {
        display: block;
        margin-bottom: 3px;
        padding-left: 11px;
        position: relative;
      }

      .group-label::before {
        content: "•";
        position: absolute;
        left: 0;
        color: #1f4f7a;
      }

      .group-block {
        margin-bottom: 8px;
      }

      .group-block:last-child {
        margin-bottom: 0;
      }

      .stack-lines {
        display: grid;
        gap: 3px;
        margin-left: 10px;
      }

      .subproject-list {
        margin-top: 6px;
        margin-left: 12px;
      }

      .subproject-item {
        margin-bottom: 5px;
        font-size: 9.9px;
        line-height: 1.34;
        padding-left: 11px;
        position: relative;
      }

      .subproject-item::before {
        content: "•";
        position: absolute;
        left: 0;
        color: #1f4f7a;
      }

      .subproject-name {
        font-weight: 700;
      }

      .citation-item {
        margin-bottom: 6px;
        font-size: 9.9px;
        line-height: 1.33;
        padding-left: 11px;
        position: relative;
      }

      .citation-item::before {
        content: "•";
        position: absolute;
        left: 0;
        color: #1f4f7a;
      }

      .footer-note {
        margin-top: 0.12in;
        font-size: 9.4px;
        color: #4b5563;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="header">
        <div class="header-row">
          <div>
            <h1 class="name">{{ basics.preferred_name }}</h1>
            <div class="headline">{{ basics.headline }}</div>
          </div>
          <div class="header-meta">Updated {{ generated_date }}</div>
        </div>
        <div class="contact">
          <div><a href="mailto:{{ basics.email }}">{{ basics.email }}</a></div>
          <div><a href="{{ basics.github }}">{{ basics.github }}</a></div>
          <div><a href="{{ basics.linkedin }}">{{ basics.linkedin }}</a></div>
          <div><a href="{{ basics.consulting }}">{{ basics.consulting }}</a></div>
          <div>{{ basics.location }}</div>
        </div>
      </header>

      <section class="section">
        <h2 class="section-title">Summary</h2>
        <div class="body-text">{{ summary }}</div>
      </section>

      <section class="section">
        <h2 class="section-title">Profile</h2>
        <div class="line-block body-text">
          <strong class="group-label">Status</strong>
          <div>{{ basics.legal_status }}</div>
        </div>
        <div class="line-block body-text">
          <strong class="group-label">Memberships</strong>
          <div>{{ awards_and_memberships | join("; ") }}</div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">Skills</h2>
        {% for group_name, lines in selected_skills_sidebar.items() %}
        <div class="group-block body-text">
          <strong class="group-label">{{ group_name }}</strong>
          <div class="stack-lines">
            {% for line in lines %}
            <div>{{ line | safe }}</div>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>

      {% if selected_tools %}
      <section class="section">
        <h2 class="section-title">Frameworks and Tools</h2>
        {% for group_name, lines in selected_tools_sidebar.items() %}
        <div class="group-block body-text">
          {% if group_name != "Selected Frameworks and Tools" %}
          <strong class="group-label">{{ group_name }}</strong>
          {% endif %}
          <div class="stack-lines">
            {% for line in lines %}
            <div>{{ line | safe }}</div>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>
      {% endif %}

      <section class="section">
        <h2 class="section-title">Education</h2>
        {% for item in education %}
        <div class="entry">
          <div class="entry-head">
            <div>
              <div class="entry-role">{{ item.degree }}</div>
              <div class="entry-company">{{ item.school }}</div>
            </div>
            <div class="entry-dates">{{ item.period }}</div>
          </div>
          {% if item.detail_rows %}
          <ul>
            {% for detail in item.detail_rows %}
            <li>{% if detail.label %}<strong>{{ detail.label }}:</strong> {% endif %}{{ detail.value }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
        {% endfor %}
      </section>

      <section class="section">
        <h2 class="section-title">Experience</h2>
        {% for item in experience %}
        <div class="entry">
          <div class="entry-head">
            <div>
              <div class="entry-role">{{ item.role }}</div>
              <div class="entry-company">{{ item.company }}</div>
            </div>
            <div class="entry-dates">{{ item.date_label }}</div>
          </div>
          <ul>
            {% for bullet in item.bullets %}
            <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </section>

      {% if projects %}
      <section class="section">
        <h2 class="section-title">Projects</h2>
        {% for item in projects %}
        <div class="entry">
          <div class="entry-head">
            <div class="entry-title-line">
              <div class="entry-role">{{ item.name }}</div>
              {% if item.badges_html %}{{ item.badges_html | safe }}{% endif %}
            </div>
            <div class="entry-dates">{{ item.period }}</div>
          </div>
          {% if item.project_type %}
          <div class="entry-company">{{ item.project_type }}</div>
          {% endif %}
          <div class="entry-summary">{{ item.summary }}</div>
          {% if item.highlights %}
          <ul>
            {% for bullet in item.highlights %}
            <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
          {% endif %}
          {% if item.children %}
          <div class="entry-summary"><strong>Selected workstreams:</strong></div>
          <div class="subproject-list">
            {% for child in item.children %}
            <div class="subproject-item">
              <span class="subproject-name">{{ child.name }}</span>{% if child.badges_html %} {{ child.badges_html | safe }}{% endif %}: {{ child.summary }}
              {% if child.project_links_html %}
              <div class="subproject-links">{{ child.project_links_html | safe }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          {% endif %}
          {% if item.project_links_html %}
          <div class="project-links">{{ item.project_links_html | safe }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </section>
      {% endif %}

      {% if publications %}
      <section class="section">
        <h2 class="section-title">Publications</h2>
        {% for item in publications %}
        <div class="citation-item">{{ item.citation }}</div>
        {% endfor %}
      </section>
      {% endif %}

      {% if patents %}
      <section class="section">
        <h2 class="section-title">Patents</h2>
        {% for item in patents %}
        <div class="citation-item">{{ item.citation }}</div>
        {% endfor %}
      </section>
      {% endif %}

      <div class="footer-note">Professional references available upon request.</div>
    </div>
  </body>
</html>
